# Copy this file to `.env` and adjust paths for your machine.
# This project uses Zhejiang University WebVPN-backed access.
# You do not need to open aTrust for the normal download workflow.

ZJU_EDGE_EDGE_BIN=/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge
ZJU_EDGE_PROFILE_DIR=./.local/edge-profile
ZJU_EDGE_DOWNLOAD_DIR=./output/final-pdfs
ZJU_EDGE_REMOTE_DEBUG_PORT=62777
